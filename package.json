{
  "name": "agent-historic",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "cli-runner-learner": "^0.3.0"
  },
  "scripts": {
    "test:unit": "node --test scripts/lib/*.test.mjs",
    "build:prompts": "node scripts/build-prompt-system.mjs",
    "build:prompts:release": "node scripts/build-prompt-system.mjs --no-debug",
    "build:prompts:debug": "node scripts/build-prompt-system.mjs --debug",
    "install:rules": "node install.js",
    "test:regressions": "node scripts/run-regressions.mjs",
    "test:regressions:smoke": "node scripts/run-regressions.mjs --suite smoke",
    "test:regressions:clr": "node scripts/run-via-clr.mjs",
    "test:regressions:clr:smoke": "node scripts/run-via-clr.mjs --suite smoke",
    "test:model-parity": "node scripts/run-regressions.mjs --local --suite model-parity --targets cursor,codex --trace --judge",
    "test:model-parity:real": "node scripts/run-regressions.mjs --suite model-parity --targets cursor,codex --trace --judge",
    "analyze:shift": "node scripts/analyze-distribution-shift.mjs",
    "test:ablation": "node scripts/run-ablation.mjs",
    "test:experiment": "node scripts/run-experiment.mjs"
  }
}
