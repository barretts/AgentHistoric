  ],
  "disambiguation": {
    "routeToPopper": [
      "tests are failing",
      "got an error",
      "build error in payment service",
      "help debug this test failure"
    ],
    "routeToQuinn": [
      "how do I write a test for",
      "refactor the test suite",
      "how should I structure tests"
    ],
    "routeToDennett": [
      "should we add tests for"
    ]
  },
  "pipelines": [
    {
      "name": "Debug Firefighting",
      "steps": [
        { "expert": "expert-qa-popper", "task": "Execute tests with Non-Destructive Logging. Capture FULL output. Parse failures." },
        { "expert": "expert-engineer-quinn", "task": "Read source files from errors. Match against known patterns. Propose fix." },
        { "expert": "expert-qa-popper", "task": "Apply fix. Re-run tests. Verify resolution." },
        { "expert": "expert-manager-blackmore", "task": "Extract pattern if novel. Update project rules." }
      ]
    },
    {
      "name": "New Feature Epic",
      "steps": [
        { "expert": "expert-visionary-dennett", "task": "Generate 3 competing architectural drafts." },
        { "expert": "expert-ux-rogers", "task": "Review drafts for cognitive load and friction. Veto hostile UI." },
        { "expert": "expert-architect-descartes", "task": "Strip assumptions. Define bedrock data layer, types, schemas." },
        { "expert": "expert-engineer-quinn", "task": "Implement pragmatically. Code + tests + verified." }
      ]
    },
    {
      "name": "Bug Triage & Resolution",
      "steps": [
        { "expert": "expert-qa-popper", "task": "Replicate the failure. Hunt the edge case. Use Non-Destructive Logging." },
        { "expert": "expert-engineer-quinn", "task": "Write the patch. Pass the tests." },
        { "expert": "expert-manager-blackmore", "task": "Extract root cause pattern. Update rules to prevent recurrence." }
      ]
    },
    {
      "name": "Automation Generation",
      "steps": [
        { "expert": "expert-architect-descartes", "task": "Deconstruct the task. Deterministic script (AST/Regex) or semantic sub-agent? Output blueprint." },
        { "expert": "expert-engineer-quinn", "task": "Implement the blueprint with strict engineering constraints." },
        { "expert": "expert-qa-popper", "task": "Run automation against a known failure point. Prove it works." },
        { "expert": "expert-manager-blackmore", "task": "Register the automation in project rules." }
      ]
    }
  ],
  "contracts": [
    "Never blend expert personas by default.",
    "When a handoff is required, name the current expert and the next expert explicitly.",
    "If a task is ambiguous, still choose one primary expert and explain why."
  ]
}
