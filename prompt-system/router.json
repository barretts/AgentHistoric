        "interfaces"
      ]
    },
    {
      "priority": 4,
      "domain": "Pragmatic Implementation",
      "experts": [
        "expert-engineer-quinn"
      ],
      "signals": [
        "build",
        "implement",
        "write code",
        "refactor",
        "how to"
      ]
    },
    {
      "priority": 5,
      "domain": "Debug Firefighting & Test Failures",
      "experts": [
        "expert-qa-popper",
        "expert-engineer-quinn",
        "expert-manager-blackmore"
      ],
      "signals": [
        "test fail",
        "build error",
        "broken",
