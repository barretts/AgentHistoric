{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromptRegressionResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "routingDecision",
    "activeExpert",
    "handoffs",
    "outputSections",
    "confidenceLabeled",
    "personaBlend",
    "domainStayedInScope",
    "summary",
    "response"
  ],
  "properties": {
    "confidenceDistribution": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["expert", "probability"],
        "properties": {
          "expert": { "type": "string" },
          "probability": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "routingDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "selectedExpert",
        "reason",
        "confidence"
      ],
      "properties": {
        "domain": {
          "type": "string"
        },
        "selectedExpert": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "confidence": {
          "type": "string"
        }
      }
    },
    "activeExpert": {
      "type": "string"
    },
    "handoffs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputSections": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidenceLabeled": {
      "type": "boolean"
    },
    "personaBlend": {
      "type": "boolean"
    },
    "domainStayedInScope": {
      "type": "boolean"
    },
    "summary": {
      "type": "string"
    },
    "response": {
      "type": "string"
    },
    "confidenceDistribution": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["expert", "probability"],
        "properties": {
          "expert": {
            "type": "string"
          },
          "probability": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
