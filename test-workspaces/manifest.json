    { "id": "gpt-5.4-medium__rich-old",       "model": "gpt-5.4-medium",      "condition": "rich-old", "depends_on": [], "timeout_sec": 180, "verify_profile": "output-exists" },
    { "id": "gpt-5.4-medium__rich-new",       "model": "gpt-5.4-medium",      "condition": "rich-new", "depends_on": [], "timeout_sec": 180, "verify_profile": "output-exists" },
    { "id": "claude-4.6-opus-high__rich-old", "model": "claude-4.6-opus-high", "condition": "rich-old", "depends_on": [], "timeout_sec": 180, "verify_profile": "output-exists" },
    { "id": "claude-4.6-opus-high__rich-new", "model": "claude-4.6-opus-high", "condition": "rich-new", "depends_on": [], "timeout_sec": 180, "verify_profile": "output-exists" },
    { "id": "grok-4-20__rich-old",            "model": "grok-4-20",            "condition": "rich-old", "depends_on": [], "timeout_sec": 180, "verify_profile": "output-exists" },
    { "id": "grok-4-20__rich-new",            "model": "grok-4-20",            "condition": "rich-new", "depends_on": [], "timeout_sec": 180, "verify_profile": "output-exists" },
    { "id": "gemini-3.1-pro__rich-old",       "model": "gemini-3.1-pro",       "condition": "rich-old", "depends_on": [], "timeout_sec": 180, "verify_profile": "output-exists" },
    { "id": "gemini-3.1-pro__rich-new",       "model": "gemini-3.1-pro",       "condition": "rich-new", "depends_on": [], "timeout_sec": 180, "verify_profile": "output-exists" }
  ]
}
